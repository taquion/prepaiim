[Unit]
Description=Portal IIM Backend (FastAPI)
After=network.target postgresql.service

[Service]
User=www-data
WorkingDirectory=/var/www/prepaiim/backend
Environment=PATH=/var/www/prepaiim/venv/bin
EnvironmentFile=/var/www/prepaiim/backend/.env
ExecStart=/var/www/prepaiim/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
